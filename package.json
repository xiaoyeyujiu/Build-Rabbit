{
  "name": "mood-buddy",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.33.0",
  "type": "module",
  "main": "electron/main.mjs",
  "scripts": {
    "dev": "node ./scripts/dev-electron.mjs",
    "dev:renderer": "vite --port=18040 --host=127.0.0.1 --strictPort",
    "build:web": "vite build",
    "build": "pnpm build:web && electron-builder",
    "build:dir": "pnpm build:web && electron-builder --dir",
    "preview": "vite preview --host 127.0.0.1 --port 4173",
    "clean": "node ./scripts/clean.mjs",
    "lint": "tsc --noEmit"
  },
  "build": {
    "appId": "com.moodbuddy.desktop",
    "productName": "Mood Buddy",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "electron/main.mjs"
    },
    "win": {
      "target": [
        "portable"
      ]
    }
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "three": "^0.183.2",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}